{
  "name": "visual-planner",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-reviewable, iterable planning for Claude Code.",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "build": "npm run build:server && npm run build:viewer",
    "build:server": "tsc -p tsconfig.server.json",
    "build:viewer": "tsc -p tsconfig.viewer.json",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.viewer.json --noEmit",
    "check": "npm run typecheck"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "marked": "^12.0.2",
    "typescript": "^5.6.3"
  }
}
